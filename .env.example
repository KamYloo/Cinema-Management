# PostgreSQL Configuration
POSTGRES_DB=cinemaData
POSTGRES_USER=postgres
POSTGRES_PASSWORD=netlab
POSTGRES_PORT=5432
DATABASE_URL=jdbc:postgresql://postgres:5432/cinemaData

# Spring Boot Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cinemaData
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=netlab
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JWT Secret (Base64 encoded, change for production)
JWT_SECRET=ThisIsASecretKeyForJWTTokenGenerationAndValidationChangeItInProduction

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=cinema-uploads

# Frontend Configuration
# Use these values in CinemaFrontend/.env when running the frontend locally
# against the VPS backend via Tailscale.
VITE_API_URL=https://100.100.119.110
VITE_WS_URL=wss://100.100.119.110/ws

# Environment
ENVIRONMENT=development
